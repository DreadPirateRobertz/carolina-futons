{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$version": "1.0.0",
  "$description": "Carolina Futons shared design tokens — platform-agnostic brand identity. Consumed by web (designTokens.js) and mobile (cfutons_mobile theme provider).",
  "brand": {
    "name": "Carolina Futons",
    "shortName": "CF Futons",
    "foundedYear": 1991
  },
  "colors": {
    "primary": {
      "sandBase": { "value": "#F0F4F8", "description": "Light blue-gray — page backgrounds" },
      "espresso": { "value": "#1E3A5F", "description": "Dark navy — primary text, headings" },
      "mountainBlue": { "value": "#5B8FA8", "description": "CF brand blue — links, accents" },
      "sunsetCoral": { "value": "#4A7D94", "description": "CF brand blue (darkened) — primary CTA, sale badges" },
      "mauve": { "value": "#C9A0A0", "description": "Soft mauve/pink — tertiary accent" },
      "white": { "value": "#FFFFFF", "description": "Pure white" }
    },
    "variants": {
      "sandLight": { "value": "#F8FAFC", "description": "Near-white — card backgrounds" },
      "sandDark": { "value": "#E2E8F0", "description": "Cool border gray — borders, dividers" },
      "espressoLight": { "value": "#3D5A80", "description": "Medium navy — secondary text" },
      "mountainBlueDark": { "value": "#3D6B80", "description": "Darker blue — hover states" },
      "mountainBlueLight": { "value": "#A8CCD8", "description": "Soft sky blue — subtle backgrounds" },
      "sunsetCoralDark": { "value": "#3D6B80", "description": "Dark blue — CTA hover" },
      "sunsetCoralLight": { "value": "#A8CCD8", "description": "Light blue — badges, highlights" }
    },
    "decorative": {
      "skyGradientTop": { "value": "#B8D4E3", "description": "Sky gradient top" },
      "skyGradientBottom": { "value": "#F0C87A", "description": "Sky gradient bottom (sunset glow)" },
      "overlay": { "value": "rgba(30, 58, 95, 0.6)", "description": "Navy modal overlay" }
    },
    "semantic": {
      "success": { "value": "#4A7C59", "description": "Forest green — in stock, success" },
      "error": { "value": "#DC2626", "description": "Red — errors, low stock" },
      "muted": { "value": "#6B7280", "description": "Slate — disabled, inactive (WCAG AA compliant)" },
      "mutedBrown": { "value": "#64748B", "description": "Slate gray — pending states" }
    }
  },
  "fontFamilies": {
    "heading": "\"Playfair Display\", Georgia, serif",
    "body": "\"Source Sans 3\", \"Helvetica Neue\", Arial, sans-serif"
  },
  "spacing": {
    "$unit": "px",
    "$base": 4,
    "xs": 4,
    "sm": 8,
    "md": 16,
    "lg": 24,
    "xl": 32,
    "xxl": 48,
    "xxxl": 64
  },
  "borderRadius": {
    "$unit": "px",
    "sm": 4,
    "md": 8,
    "lg": 12,
    "xl": 16,
    "pill": 9999
  },
  "shadows": {
    "card": { "x": 0, "y": 2, "blur": 12, "color": "rgba(30, 58, 95, 0.08)" },
    "cardHover": { "x": 0, "y": 8, "blur": 24, "color": "rgba(30, 58, 95, 0.12)" },
    "nav": { "x": 0, "y": 2, "blur": 8, "color": "rgba(30, 58, 95, 0.06)" },
    "modal": { "x": 0, "y": 16, "blur": 48, "color": "rgba(30, 58, 95, 0.2)" },
    "button": { "x": 0, "y": 2, "blur": 8, "color": "rgba(91, 143, 168, 0.3)" }
  },
  "transitions": {
    "$unit": "ms",
    "fast": 150,
    "medium": 250,
    "slow": 400
  },
  "breakpoints": {
    "$unit": "px",
    "mobile": 320,
    "mobileLarge": 480,
    "tablet": 768,
    "desktop": 1024,
    "wide": 1280,
    "ultraWide": 1440
  }
}
