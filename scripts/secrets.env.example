# Carolina Futons — Wix Secrets Manager values
# Copy to secrets.env and fill in real values before running provisionSecrets.js
#
# Usage:
#   node scripts/provisionSecrets.js --values scripts/secrets.env --dry-run
#   node scripts/provisionSecrets.js --values scripts/secrets.env
#
# Requires WIX_API_KEY and WIX_SITE_ID environment variables.

# UPS Shipping (get from developer.ups.com)
UPS_CLIENT_ID=
UPS_CLIENT_SECRET=
UPS_ACCOUNT_NUMBER=
UPS_SANDBOX=true

# Site owner — Brenda's Wix contact UUID (Dashboard > Contacts > click Brenda > copy ID from URL)
SITE_OWNER_CONTACT_ID=

# Backend API key (Dashboard > Settings > API Keys)
WIX_BACKEND_KEY=

# Discount codes — create in Dashboard > Marketing > Coupons first
WELCOME_DISCOUNT_CODE=WELCOME10
RECOVERY_DISCOUNT_CODE=COMEBACK15
